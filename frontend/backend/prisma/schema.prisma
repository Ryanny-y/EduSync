generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum FileType {
  PDF
  PPT
  DOC
  VIDEO
}

enum NotificationType {
  LESSON
  RECITATION
  ASSIGNMENT
  SYSTEM
}

//////////////////////
// MODELS
//////////////////////

// 1️⃣ Department
model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  teachers  User[]
  createdAt DateTime @default(now())
}

// 2️⃣ User
model User {
  id           String  @id @default(uuid())
  firstName    String
  middleName   String?
  lastName     String
  email        String  @unique
  passwordHash String

  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?

  role         Role
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String? // only for teachers

  classesTeaching Class[] @relation("TeacherClasses") // Teacher
  joinedClasses   Class[] @relation("StudentClasses") // Student

  recitations   Recitation[]
  submissions   Submission[]
  notifications NotificationRecipient[]
  activityLogs  ActivityLog[]
  syncLogs      SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3️⃣ Class
model Class {
  id        String  @id @default(uuid())
  name      String
  subject   String
  section   String
  time      String
  room      String
  gmeetLink String?
  code      String  @unique // student join code

  teacher   User   @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId String

  students      User[]         @relation("StudentClasses")
  lessons       Lesson[]
  recitations   Recitation[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4️⃣ Lesson
model Lesson {
  id          String           @id @default(uuid())
  title       String
  class       Class            @relation(fields: [classId], references: [id])
  classId     String
  materials   LessonMaterial[]
  submissions Submission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// 5️⃣ Lesson Material
model LessonMaterial {
  id        String   @id @default(uuid())
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  lessonId  String
  file      File     @relation(fields: [fileId], references: [id])
  fileId    String
  createdAt DateTime @default(now())
}

// 6️⃣ File
model File {
  id              String           @id @default(uuid())
  fileName        String
  fileType        FileType
  path            String
  size            Int
  lessonMaterials LessonMaterial[]
  submissions     SubmissionFile[]
  createdAt       DateTime         @default(now())
}

// 7️⃣ Submission
model Submission {
  id        String           @id @default(uuid())
  student   User             @relation(fields: [studentId], references: [id])
  studentId String
  lesson    Lesson           @relation(fields: [lessonId], references: [id])
  lessonId  String
  files     SubmissionFile[]
  createdAt DateTime         @default(now())
}

// Join table Submission ↔ File
model SubmissionFile {
  id           String     @id @default(uuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String
  file         File       @relation(fields: [fileId], references: [id])
  fileId       String
}

// 8️⃣ Recitation
model Recitation {
  id        String   @id @default(uuid())
  question  String
  student   User     @relation(fields: [studentId], references: [id])
  studentId String
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  answer    String?
  score     Float?
  feedback  String?
  createdAt DateTime @default(now())

  @@unique([studentId, classId, question])
}

// 10️⃣ Notification
model Notification {
  id         String                  @id @default(uuid())
  title      String
  message    String
  type       NotificationType
  class      Class?                  @relation(fields: [classId], references: [id])
  classId    String?
  recipients NotificationRecipient[]
  createdAt  DateTime                @default(now())
}

// Join table Notification ↔ User
model NotificationRecipient {
  id             String       @id @default(uuid())
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([notificationId, userId])
}

// 11️⃣ ActivityLog
model ActivityLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  createdAt DateTime @default(now())
}

// 12️⃣ SyncLog
model SyncLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  entity    String
  status    String
  createdAt DateTime @default(now())
}
