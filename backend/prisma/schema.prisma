generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum FileType {
  PDF
  PPT
  DOC
  VIDEO
}

enum NotificationType {
  LESSON
  RECITATION
  ASSIGNMENT
  SYSTEM
}

enum WorkType {
  ASSIGNMENT
  QUIZ
  TASK
  PROJECT
}

//////////////////////
// MODELS
//////////////////////

// Department
model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  teachers  User[]
  createdAt DateTime @default(now())
}

// User
model User {
  id           String  @id @default(uuid())
  firstName    String
  middleName   String?
  lastName     String
  email        String  @unique
  passwordHash String

  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime?

  role         Role
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String? // only for teachers

  classesTeaching Class[] @relation("TeacherClasses") // Teacher
  joinedClasses   Class[] @relation("StudentClasses") // Student

  announcements Announcement[]
  submissions   Submission[]
  activityLogs  ActivityLog[]
  syncLogs      SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Class
model Class {
  id        String  @id @default(uuid())
  name      String
  subject   String
  section   String
  time      String
  room      String
  gmeetLink String?
  code      String  @unique // student join code
  bgColor   String?

  teacher   User   @relation("TeacherClasses", fields: [teacherId], references: [id])
  teacherId String

  announcements Announcement[]
  students      User[]         @relation("StudentClasses")
  lessons       Lesson[]
  works         Work[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Work
model Work {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        WorkType
  dueDate     DateTime?

  class   Class  @relation(fields: [classId], references: [id])
  classId String

  materials   WorkMaterial[]
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkMaterial {
  id        String   @id @default(uuid())
  work      Work     @relation(fields: [workId], references: [id])
  workId    String
  file      File     @relation(fields: [fileId], references: [id])
  fileId    String
  createdAt DateTime @default(now())
}

// Lesson
model Lesson {
  id      String @id @default(uuid())
  title   String
  class   Class  @relation(fields: [classId], references: [id])
  classId String

  materials LessonMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Lesson Material  
model LessonMaterial {
  id        String   @id @default(uuid())
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  lessonId  String
  file      File     @relation(fields: [fileId], references: [id])
  fileId    String
  createdAt DateTime @default(now())
}

// Announcement
model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String

  class     Class    @relation(fields: [classId], references: [id])
  classId   String

  author    User     @relation(fields: [authorId], references: [id])
  authorId  String

  files     AnnouncementFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// Announcement file
model AnnouncementFile {
  id             String       @id @default(uuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id])
  announcementId String
  file           File         @relation(fields: [fileId], references: [id])
  fileId         String

  createdAt DateTime @default(now())
}

// File
model File {
  id       String   @id @default(uuid())
  fileName String
  fileType FileType
  path     String
  size     Int

  workMaterials   WorkMaterial[]
  lessonMaterials LessonMaterial[]
  submissions     SubmissionFile[]

  createdAt         DateTime           @default(now())
  announcementFiles AnnouncementFile[]
}

// Submission
model Submission {
  id        String @id @default(uuid())
  student   User   @relation(fields: [studentId], references: [id])
  studentId String

  work   Work   @relation(fields: [workId], references: [id])
  workId String

  files SubmissionFile[]

  grade    Float?
  feedBack String?

  createdAt DateTime @default(now())

  @@unique([studentId, workId])
}

// Join table Submission ↔ File
model SubmissionFile {
  id           String     @id @default(uuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String
  file         File       @relation(fields: [fileId], references: [id])
  fileId       String
}

// ActivityLog
model ActivityLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String
  createdAt DateTime @default(now())
}

// SyncLog
model SyncLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  entity    String
  status    String
  createdAt DateTime @default(now())
}
